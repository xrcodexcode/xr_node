{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NexusDB Map of Content Schema",
  "type": "object",
  "allOf": [
    { "$ref": "frontmatter.schema.json" },
    {
      "properties": {
        "type": {
          "type": "string",
          "enum": ["moc"]
        },
        "status": {
          "type": "string",
          "enum": ["active", "curated", "archived"]
        }
      }
    }
  ]
}
