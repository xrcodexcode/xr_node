{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NexusDB Atomic Note Schema",
  "type": "object",
  "allOf": [
    { "$ref": "frontmatter.schema.json" },
    {
      "properties": {
        "type": {
          "type": "string",
          "enum": ["atomic-note"]
        }
      }
    }
  ],
  "if": {
    "properties": { "schema_version": { "const": 4 } },
    "required": ["schema_version"]
  },
  "then": {
    "properties": {
      "owner_moc": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": ["owner_moc"]
  }
}
